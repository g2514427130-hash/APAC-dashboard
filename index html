        // 计算区域装机数据
        function calculateRegionalData() {
            let currentSolar = 0, currentWind = 0, currentHydro = 0, currentBiomass = 0;
            let targetSolar = 0, targetWind = 0, targetHydro = 0, targetBiomass = 0;

            Object.values(countryData).forEach(country => {
                // 当前新能源装机（基于current中的新能源部分）
                if (country.current.solar) currentSolar += country.currentCapacity * country.current.solar / 100;
                if (country.current.wind) currentWind += country.currentCapacity * country.current.wind / 100;
                if (country.current.hydro) currentHydro += country.currentCapacity * country.current.hydro / 100;
                if (country.current.biomass) currentBiomass += country.currentCapacity * country.current.biomass / 100;

                // 2030目标装机
                targetSolar += country.solar;
                targetWind += country.wind;
                targetHydro += country.hydro;
                targetBiomass += country.biomass;
            });

            return {
                current: { solar: currentSolar.toFixed(1), wind: currentWind.toFixed(1), hydro: currentHydro.toFixed(1), biomass: currentBiomass.toFixed(1) },
                target: { solar: targetSolar, wind: targetWind, hydro: targetHydro, biomass: targetBiomass }
            };
        }

        // 显示区域装机详情
