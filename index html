        // 根据参数计算功率曲线数据（按照Excel操作模式）
        function calculatePowerProfile(pvCapacity, bessCapacity, targetYearSOH, chargeEfficiency, dischargeEfficiency, dod) {
            // Excel中的24小时光伏发电比例 (从C7:C30提取)
            const solarProfile = [0, 0, 0, 0, 0, 0, 0.05, 0.15, 0.35, 0.6, 0.85, 0.95, 1.0, 0.95, 0.8, 0.55, 0.3, 0.1, 0.02, 0, 0, 0, 0, 0];
            const solar = solarProfile.map(v => v * pvCapacity); // MW

            // 每日光伏发电总量 (Excel I6 = SUM(C7:C30))
            const dailyPVGeneration = solar.reduce((sum, val) => sum + val, 0); // MWh

            // Target Year实际容量 (Excel I3 = C8 * I2)
            const targetYearCapacity = bessCapacity * targetYearSOH; // MWh

            // 计算放电功率 (Excel I4)
            // I4 = MIN(I3*DoD*DischEff/4, I6*ChrgEff*DischEff/4)
            const dischargePower = Math.min(
                targetYearCapacity * dod * dischargeEfficiency / 4,
                dailyPVGeneration * chargeEfficiency * dischargeEfficiency / 4
            ); // MW

            // 充电逻辑 (Excel C7:C30 + D列)
            // 7-16点充电，功率等于PV发电 (负值表示充电)
            const charge = solarProfile.map((v, i) => {
                if (i >= 6 && i <= 16 && v > 0) {
                    return -v * pvCapacity; // 负值表示充电
                }
                return 0;
            });

            // 放电逻辑 (Excel E26:E29)
            // 19-22点放电4小时，功率固定为dischargePower
            const discharge = solarProfile.map((v, i) => {
                if (i >= 19 && i <= 22) {
                    return dischargePower;
                }
                return 0;
            });

            // BESS输出功率 (Excel F列)
            // Net = PV + Charge + Discharge
            const bessOutput = solar.map((v, i) => v + charge[i] + discharge[i]);

            console.log('功率曲线计算 (Excel逻辑):', {
                dailyPVGeneration: dailyPVGeneration.toFixed(6),
                targetYearCapacity: targetYearCapacity.toFixed(6),
                dischargePower: dischargePower.toFixed(6),
                '充电逻辑': '7-16点: Charge = -PV',
                '放电逻辑': '19-22点: Discharge = MIN(容量*DoD*Eff, PV总量*Eff)/4'
            });

            return { solar, charge, discharge, bessOutput, dischargePower };
        }

