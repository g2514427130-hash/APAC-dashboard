                        transition: all 0.2s ease;
                        margin-right: 8px;
                    " onmouseover="this.style.background='rgba(13,148,136,0.8)'" onmouseout="this.style.background='var(--accent-teal)'">
                        <span>🔗</span>
                        <span>查看原文</span>
                    </a>
                `;
            }
            if (policy.source) {
                linksHtml += `
                    <span style="
                        display: inline-flex;
                        align-items: center;
                        gap: 6px;
                        padding: 10px 16px;
                        background: var(--bg-tertiary);
                        border: 1px solid var(--border-default);
                        border-radius: 6px;
                        color: var(--text-tertiary);
                        font-size: 0.8125rem;
                    ">
                        <span>📢</span>
                        <span>${policy.source}</span>
                    </span>
                `;
            }
            
            document.getElementById('policyDetailMeta').innerHTML = `
                <span>📅 ${formatDate(policy.date)}</span>
                <span>🏷️ ${policy.typeName}</span>
                <span>⭐ ${getImportanceText(policy.importance)}</span>
                ${linksHtml ? '<div style="margin-top: 8px;">' + linksHtml + '</div>' : ''}
            `;
            
            document.getElementById('policyDetailContent').innerHTML = `
                <p style="margin-bottom: 16px; color: var(--text-secondary); font-style: italic;">
                    ${policy.summary}
                </p>
                ${policy.content}
            `;
            
            // 显示弹窗
            document.getElementById('policyDetailModal').classList.add('active');
        }

        // 关闭政策详情
        function closePolicyDetail() {
            document.getElementById('policyDetailModal').classList.remove('active');
        }

        // 更新刷新状态
        function updateRefreshStatus(status, state) {
            document.getElementById('policyRefreshStatus').textContent = status;
            const dot = document.getElementById('policyRefreshDot');
            dot.classList.remove('updating', 'error');
            if (state) {
                dot.classList.add(state);
            }
        }

        // 启动定时刷新检查
        function startRefreshInterval() {
            // 每小时检查一次
            refreshInterval = setInterval(() => {
                const cachedTime = localStorage.getItem('policyRefreshTime');
                if (cachedTime) {
                    const timeDiff = Date.now() - parseInt(cachedTime);
                    const oneDay = 24 * 60 * 60 * 1000;
                    
                    // 如果超过1天未刷新，显示提示
                    if (timeDiff > oneDay) {
                        updateRefreshStatus('需要刷新', 'updating');
                    }
                }
            }, 60 * 60 * 1000); // 每小时检查
        }

        // 格式化日期
        function formatDate(dateStr) {
            const date = new Date(dateStr);
            return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
        }

        // 格式化日期时间
        function formatDateTime(date) {
            return `${formatDate(date)} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
        }

        // 获取重要度文本
        function getImportanceText(importance) {
            const map = {
                'high': '高重要度',
                'medium': '中重要度',
                'low': '低重要度'
            };
            return map[importance] || importance;
        }

        // 显示Toast通知
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <span>${type === 'success' ? '✅' : '❌'}</span>
                <span>${message}</span>
            `;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }

        // 点击弹窗外部关闭
        document.addEventListener('click', function(e) {
            const modal = document.getElementById('policyDetailModal');
            if (e.target === modal) {
                closePolicyDetail();
            }
        });

        // ESC键关闭弹窗
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closePolicyDetail();
            }
        });

        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', function() {
            initPolicies();
        });

        // 清理定时器
        window.addEventListener('beforeunload', function() {
            if (refreshInterval) {
                clearInterval(refreshInterval);
            }
        });
    </script>

