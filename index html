            const cRate = parseFloat(document.getElementById('cRate').value) || 0.5;
            const pvUnitCost = parseFloat(document.getElementById('pvUnitCost').value) || 0.46;
            const bessUnitCost = parseFloat(document.getElementById('bessUnitCost').value) || 0.18;
            const exchangeRate = parseFloat(document.getElementById('exchangeRate').value) || 56.5;
            const peakTariff = parseFloat(document.getElementById('peakTariff').value) || 12.7;
            const offPeakTariff = parseFloat(document.getElementById('offPeakTariff').value) || 0;
            const chargeEfficiency = parseFloat(document.getElementById('chargeEfficiency').value) / 100 || 0.9345;
            const dischargeEfficiency = parseFloat(document.getElementById('dischargeEfficiency').value) / 100 || 0.9444;
            const dod = parseFloat(document.getElementById('dod').value) / 100 || 0.95;
            const taxFreeYears = parseInt(document.getElementById('taxFreeYears').value) || 7;
            const incomeTaxRate = parseFloat(document.getElementById('incomeTaxRate').value) / 100 || 0.25;
            const discountRate = parseFloat(document.getElementById('discountRate').value) / 100 || 0.05;
            const projectLife = parseInt(document.getElementById('projectLife').value) || 20;
            const debtRatio = parseFloat(document.getElementById('debtRatio').value) / 100 || 0.70;
            const loanInterestRate = parseFloat(document.getElementById('loanInterestRate').value) / 100 || 0.07;
            const loanTerm = parseInt(document.getElementById('loanTerm').value) || 10;
            const opexRate = 0.01; // 1% OPEX

            console.log('输入参数 - PV Capacity:', pvCapacity, 'Target Year:', targetYear);

            // 辅助函数：PMT计算
            const calculatePMT = (rate, nper, pv) => {
                if (rate === 0) {
                    return -pv / nper;
                }
                return -pv * rate / (1 - Math.pow(1 + rate, -nper));
            };

            // 辅助函数：IRR计算（牛顿迭代法）
            const calculateIRR = (flows, guess = 0.5) => {
                const maxIter = 200;
                const tolerance = 0.000001;
                let irr = guess;

                for (let i = 0; i < maxIter; i++) {
                    let npv = 0;
                    let dnpv = 0;

                    for (let t = 0; t < flows.length; t++) {
                        npv += flows[t] / Math.pow(1 + irr, t);
                        dnpv -= t * flows[t] / Math.pow(1 + irr, t + 1);
                    }

                    if (Math.abs(npv) < tolerance) {
                        return irr;
                    }

                    irr = irr - npv / dnpv;
                }

                return irr;
            };

            // Excel公式: Final BESS Capacity = IF(Mode="Recommended", L5, C5)
            let finalBessCapacity;
            if (bessMode === 'Recommended') {
                // Excel L5公式: Recommended Initial Capacity = (Daily PV Generation × Charge Efficiency%) / (Target Year SOH × DoD%)
                // Excel L3: Daily PV Generation Total = PV Capacity × 6.67 (hours/day)
                const dailyPVGeneration = pvCapacity * 6.67; // MWh/day
                const targetSOH = sohData[targetYear].soh;
                const recommendedInitialCapacity = (dailyPVGeneration * chargeEfficiency) / (targetSOH * dod);
                finalBessCapacity = recommendedInitialCapacity;
                document.getElementById('finalBessCapacity').value = finalBessCapacity.toFixed(4);
                document.getElementById('recommendedCapacity').value = recommendedInitialCapacity.toFixed(4);

                // 动态更新SOH表中的所有容量（容量 = 推荐初始容量 × SOH）
                for (let i = 0; i < sohData.length; i++) {
                    sohData[i].capacity = recommendedInitialCapacity * sohData[i].soh;
                }
                console.log('推荐初始容量:', recommendedInitialCapacity.toFixed(4), 'MWh');
            } else {
                finalBessCapacity = bessManualCapacity;
                document.getElementById('finalBessCapacity').value = finalBessCapacity.toFixed(4);

                // 手动模式下，SOH容量基于手动输入的初始容量
                for (let i = 0; i < sohData.length; i++) {
                    sohData[i].capacity = bessManualCapacity * sohData[i].soh;
                }
                console.log('手动初始容量:', bessManualCapacity.toFixed(4), 'MWh');
            }

            // Excel公式: Year 0 Investment = -[PV_Capacity*1000000*PV_UnitCost + BESS_Capacity*1000000*BESS_UnitCost]
            const pvCost = pvCapacity * 1000000 * pvUnitCost; // USD
            const bessCost = finalBessCapacity * 1000000 * bessUnitCost; // USD
            const year0Investment = -(pvCost + bessCost);
            console.log('Year 0 Investment:', year0Investment.toFixed(2), 'USD');

            // Excel公式: Operation Profile Discharge = 58.8654 MWh/day
            // Excel公式: I6 = SUM(C7:C30) = PV Capacity × 6.67
            // PV Profile系数和 = 0.05+0.15+0.35+0.6+0.85+0.95+1.0+0.95+0.8+0.55+0.3+0.1+0.02 = 6.67
            const operationProfileDischarge = pvCapacity * 6.67;

            // 初始化现金流数组
            const cashFlows = [year0Investment];
            // Excel公式: Year 0 Equity NCF = Year 0 Project NCF * (1 - Debt_Ratio%)
            const equityCashFlows = [year0Investment * (1 - debtRatio)];
            const cumulativeNCF = [year0Investment];

            // Excel公式: PMT(Loan_Interest_Rate, Loan_Term, -Year0_Investment * Debt_Ratio%)
            const loanAmount = Math.abs(year0Investment) * debtRatio;
            const loanPMT = calculatePMT(loanInterestRate, loanTerm, loanAmount);
            console.log('贷款金额:', loanAmount.toFixed(2), 'USD, PMT:', loanPMT.toFixed(2), 'USD/年');

            // 计算每年的财务数据
            let paybackFound = false;
            let paybackPeriod = 0;

            // 初始化window数据存储
            window.operationData = [];

            // 计算Target Assessment Year之前的固定放电量
            // 使用Target Year的实际容量（初始容量 × Target Year SOH）
            // 目标年份越低，SOH越高，实际容量越大，放电量越大
            const targetYearSOH = sohData[targetYear].soh;
            const targetYearCapacity = finalBessCapacity * targetYearSOH;
            // Excel公式: L12 = 365*4*MIN(L4*C8*DoD*DischEff/4, I6*ChrgEff*DischEff/4)
            const fixedDischarge = 365 * 4 * Math.min(
                targetYearCapacity * dod * dischargeEfficiency / 4,
                operationProfileDischarge * chargeEfficiency * dischargeEfficiency / 4
            );
            console.log('Target Year前固定放电量:', fixedDischarge.toFixed(2), 'MWh/年');
            console.log('  - 初始容量:', finalBessCapacity.toFixed(2), 'MWh');
            console.log('  - Target Year SOH:', targetYearSOH.toFixed(4));
            console.log('  - Target Year实际容量:', targetYearCapacity.toFixed(2), 'MWh');
            console.log('  - 逻辑：Target Year越低 → SOH越高 → 实际容量越大 → 放电量越大 → 收入越高 → 回本越快');

            for (let year = 1; year <= projectLife; year++) {
                // Excel公式: Actual BESS Capacity = SOH_Year × Initial_Capacity
                const actualCapacity = sohData[year] ? sohData[year].capacity : finalBessCapacity;

                // Excel公式: Annual Discharge
                // IF(Year <= Target Year, 固定放电量, 基于实际容量计算)
                let annualDischarge;
                if (year <= targetYear) {
                    annualDischarge = fixedDischarge;
                } else {
                    // Excel公式: MIN(Actual_Capacity*DoD*DischEff/4, PV_Total*ChrgEff*DischEff/4)
                    // 不使用cRate，cRate只影响功率曲线，不影响年度放电量
                    annualDischarge = 365 * 4 * Math.min(
                        actualCapacity * dod * dischargeEfficiency / 4,
                        operationProfileDischarge * chargeEfficiency * dischargeEfficiency / 4
                    );
                }

                // Excel公式: Gross Revenue = Annual_Discharge * 1000 * (Peak_Tariff - Off_Peak_Tariff) / Exchange_Rate
                const grossRevenue = annualDischarge * 1000 * (peakTariff - offPeakTariff) / exchangeRate;

                // Excel公式: OPEX = ABS(Year0_Investment) * OPEX_Rate
                const opex = Math.abs(year0Investment) * opexRate;

                // Excel公式: EBITDA = Gross Revenue - OPEX
                const ebitda = grossRevenue - opex;

                // Excel公式: Tax = IF(Year > Tax_Free_Years, EBITDA * Income_Tax_Rate, 0)
                const tax = year > taxFreeYears ? ebitda * incomeTaxRate : 0;

                // Excel公式: Project NCF = EBITDA - Tax
                const projectNCF = ebitda - tax;
                cashFlows.push(projectNCF);

                // Excel公式: Equity NCF
                // Year 1-Loan Term: Project NCF + PMT (贷款还款为负数，所以是加上PMT)
                // Year Loan Term+1-20: Project NCF (没有贷款还款)
                let equityNCF;
                if (year <= loanTerm) {
                    equityNCF = projectNCF + loanPMT;
                } else {
                    equityNCF = projectNCF;
                }
                equityCashFlows.push(equityNCF);

                // Excel公式: Cumulative NCF
                const cumNCF = cumulativeNCF[cumulativeNCF.length - 1] + projectNCF;
                cumulativeNCF.push(cumNCF);

                // Excel公式: Payback Period
                if (!paybackFound && cumNCF >= 0) {
                    const prevCumNCF = cumulativeNCF[cumulativeNCF.length - 2];
                    paybackPeriod = year - 1 + Math.abs(prevCumNCF) / projectNCF;
                    paybackFound = true;
                }

                // 存储年度运营数据用于导出
                window.operationData.push({
                    year: year,
                    annualDischarge: annualDischarge,
                    revenue: grossRevenue,
                    opex: opex
                });

                if (year <= 5 || year >= 19) {
                    console.log(`Year ${year}: Capacity=${actualCapacity.toFixed(2)}, Discharge=${annualDischarge.toFixed(2)}, Revenue=${grossRevenue.toFixed(2)}, NCF=${projectNCF.toFixed(2)}`);
                }
            }

            // Excel公式: NPV = NPV(Discount_Rate, Year1_Flows) + Year0_Flow
            let npv = year0Investment;
            for (let t = 1; t < cashFlows.length; t++) {
                npv += cashFlows[t] / Math.pow(1 + discountRate, t);
            }

            // Excel公式: Project IRR = IRR(Cash_Flows) * 100
            const projectIRR = calculateIRR(cashFlows, 0.5) * 100;

            // Excel公式: Equity IRR = IRR(Equity_Cash_Flows) * 100
            const equityIRR = calculateIRR(equityCashFlows, 0.5) * 100;

            console.log('KPI结果:', {
                paybackPeriod: paybackPeriod.toFixed(2),
                projectIRR: projectIRR.toFixed(2),
                equityIRR: equityIRR.toFixed(2),
                npv: npv.toFixed(2)
            });

            // 更新KPI显示
            document.getElementById('paybackPeriod').textContent = paybackPeriod.toFixed(2) + ' 年';
            document.getElementById('projectIRR').textContent = projectIRR.toFixed(2) + '%';
            document.getElementById('equityIRR').textContent = equityIRR.toFixed(2) + '%';
            document.getElementById('npv').textContent = '$' + Math.round(npv).toLocaleString();

            // 更新财务数据
            financialResults.paybackPeriod = paybackPeriod;
            financialResults.projectIRR = projectIRR;
            financialResults.equityIRR = equityIRR;
            financialResults.npv = npv;
            financialResults.cumulativeNCF = cumulativeNCF;

            // 存储现金流数据到window用于导出
            window.cashFlowData = [];
            for (let i = 0; i < cashFlows.length; i++) {
                window.cashFlowData.push({
                    year: i,
                    projectNCF: cashFlows[i],
                    equityNCF: equityCashFlows[i],
                    cumulativeNCF: cumulativeNCF[i]
                });
            }

            // 存储财务数据到window用于导出
            window.financialData = {
                paybackPeriod: paybackPeriod,
                projectIRR: projectIRR,
                equityIRR: equityIRR,
                npv: npv,
                totalInvestment: Math.abs(year0Investment)
            };

            // 确保SOH数据在window上
            window.sohData = sohData;

            // 更新功率曲线数据
            powerData = calculatePowerProfile(pvCapacity, finalBessCapacity, targetYearSOH, chargeEfficiency, dischargeEfficiency, dod);

            // 更新图表
            updateCharts(cumulativeNCF, paybackPeriod);
            updatePowerProfileChart();

            console.log('=== 重新计算完成 ===');
        }

