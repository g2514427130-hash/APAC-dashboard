<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>亚太地面光储业务看板 - v87 官方政策链接版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@4.9.0/map/js/world.js"></script>
    <!-- SheetJS Pro版本 - 支持图表 -->
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            /* 商务专业配色方案 */
            --bg-primary: #0a1118;
            --bg-secondary: #0f1623;
            --bg-tertiary: #151c2e;
            --bg-card: #121928;
            --bg-card-hover: #192236;
            --border-subtle: rgba(255,255,255,0.03);
            --border-default: rgba(255,255,255,0.06);
            --border-strong: rgba(255,255,255,0.1);
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --text-tertiary: #64748b;
            --accent-gold: #c9a227;
            --accent-gold-glow: rgba(201,162,39,0.3);
            --accent-blue: #3b82f6;
            --accent-blue-glow: rgba(59,130,246,0.3);
            --accent-teal: #0d9488;
            --accent-teal-glow: rgba(13,148,136,0.3);
            --accent-green: #22c55e;
            --accent-red: #ef4444;
            --accent-navy: #1e3a5f;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.5);
            --shadow: 0 4px 12px rgba(0,0,0,0.6);
            --shadow-lg: 0 10px 40px rgba(0,0,0,0.7);
            --shadow-glow: 0 0 24px var(--accent-gold-glow);
        }
        
        body { 
            background: var(--bg-primary);
            color: var(--text-primary);
            font-family: "Noto Sans SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            line-height: 1.6;
            position: relative;
            overflow-x: hidden;
        }

        /* 背景纹理 - 商务风格 */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(ellipse at 15% 15%, rgba(59,130,246,0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 85% 85%, rgba(201,162,39,0.03) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }
        
        .container { 
            max-width: 1920px; 
            margin: 0 auto; 
            padding: 24px 32px; 
            position: relative;
            z-index: 1;
        }
        
        /* 头部 - 优化设计 */
        .header { 
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px; 
            padding: 24px 32px;
            background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
            border: 1px solid var(--border-default);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent);
            opacity: 0.5;
        }
        
        .header-left h1 {
            font-size: 1.875rem;
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: -0.01em;
            display: flex;
            align-items: baseline;
            gap: 12px;
        }

        .header-left .watermark {
            font-size: 0.75rem;
            font-weight: 400;
            color: var(--text-secondary);
            letter-spacing: 0.02em;
            opacity: 0.8;
        }
        
        .header-left .subtitle { 
            color: var(--text-tertiary); 
            font-size: 0.875rem;
            margin-top: 6px;
            font-weight: 400;
            letter-spacing: 0.02em;
        }
        
        .header-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            font-size: 0.8125rem;
            color: var(--text-secondary);
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .header-badge:hover {
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }

        .header-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--accent-teal);
            border-radius: 50%;
        }


        
        /* 统计卡片 - 优化设计 */
        .stats-grid { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            gap: 20px; 
            margin-bottom: 24px; 
        }
        
        .stat-card { 
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 8px; 
            padding: 20px 24px;
            transition: all 0.3s ease;
            position: relative;
            cursor: pointer;
        }

        .stat-card:hover {
            border-color: var(--accent-gold);
            background: var(--bg-card-hover);
        }

        .stat-card.gold { --card-accent: var(--accent-gold); }
        .stat-card.blue { --card-accent: var(--accent-blue); }
        .stat-card.teal { --card-accent: var(--accent-teal); }
        .stat-card.navy { --card-accent: var(--accent-navy); }
        
        .stat-card.interactive {
            cursor: pointer;
        }

        .stat-card.interactive::after {
            content: '点击查看详情';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 8px 16px;
            border-radius: 4px;
            font-size: 0.75rem;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            white-space: nowrap;
        }

        .stat-card.interactive:hover::after {
            opacity: 1;
        }
        
        .stat-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }
        
        .stat-icon {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }
        
        .stat-icon.gold { 
            background: rgba(201,162,39,0.12);
            border: 1px solid rgba(201,162,39,0.25);
        }
        .stat-icon.blue { 
            background: rgba(59,130,246,0.12);
            border: 1px solid rgba(59,130,246,0.25);
        }
        .stat-icon.teal { 
            background: rgba(13,148,136,0.12);
            border: 1px solid rgba(13,148,136,0.25);
        }
        .stat-icon.navy { 
            background: rgba(30,58,95,0.3);
            border: 1px solid rgba(30,58,95,0.4);
        }
        
        .stat-label { 
            color: var(--text-secondary); 
            font-size: 0.8125rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .stat-value { 
            font-size: 2rem; 
            font-weight: 600; 
            color: var(--text-primary);
            line-height: 1;
        }
        
        .stat-value.gold { 
            color: var(--accent-gold);
        }
        .stat-value.blue { 
            color: var(--accent-blue);
        }
        .stat-value.teal { 
            color: var(--accent-teal);
        }
        .stat-value.navy { 
            color: var(--accent-navy);
        }

        /* 商业模式卡片 */
        .business-model-card {
            background: var(--bg-card);
            border: 1px solid var(--border-default);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .business-model-card:hover {
            border-color: var(--accent-gold);
            box-shadow: var(--shadow-glow);
        }

        .business-model-header {
            display: flex;
            align-items: center;
            padding: 14px 16px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-default);
        }

        .business-model-icon {
            font-size: 1.6rem;
            margin-right: 12px;
        }

        .business-model-label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .business-model-body {
            padding: 12px;
        }

        .business-model-tabs {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
        }

        .business-model-tab {
            padding: 10px 8px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            text-align: center;
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .business-model-tab:hover {
            background: var(--bg-card-hover);
            border-color: var(--border-default);
            color: var(--text-primary);
        }

        .business-model-tab.active {
            background: var(--accent-gold-glow);
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }
        
        /* 主网格 */
        .main-grid { 
            display: grid; 
            grid-template-columns: 2fr 1fr; 
            gap: 20px; 
        }
        
        .panel { 
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 8px; 
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .panel:hover {
            border-color: var(--border-default);
        }
        
        .panel-header { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .panel-title { 
            font-size: 0.9375rem; 
            font-weight: 600; 
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .panel-title::before {
            content: '';
            width: 3px;
            height: 16px;
            background: var(--accent-gold);
            border-radius: 1px;
        }
        
        .panel-body {
            padding: 24px;
        }
        
        .btn-text {
            padding: 6px 14px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 4px;
            color: var(--text-secondary);
            font-size: 0.8125rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .btn-text:hover {
            background: var(--bg-card-hover);
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }
        
        #mapChart { width: 100%; height: 500px; }
        #targetChart { width: 100%; height: 240px; }
        #pieChart { width: 100%; height: 220px; }
        
        .right-panels { 
            display: flex; 
            flex-direction: column; 
            gap: 20px; 
        }
        
        .legend { 
            display: flex; 
            justify-content: center; 
            gap: 28px; 
            margin-top: 20px; 
            padding-top: 20px;
            border-top: 1px solid var(--border-subtle);
        }
        
        .legend-item { 
            display: flex; 
            align-items: center; 
            gap: 10px; 
            font-size: 0.8125rem; 
            color: var(--text-secondary);
            font-weight: 500;
        }
        
        .legend-dot { 
            width: 12px; 
            height: 12px; 
            border-radius: 3px;
        }
        
        .legend-dot.high { 
            background: var(--accent-rose);
        }
        .legend-dot.medium { 
            background: var(--accent-amber);
        }
        .legend-dot.low { 
            background: var(--accent-cyan);
        }
        .legend-dot.other { 
            background: var(--bg-tertiary); 
            border: 1px solid var(--border-default);
        }
        
        /* 底部电价卡片 */
        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }
        
        /* 弹窗 - 优化设计 */
        .modal { 
            display: none; 
            position: fixed; 
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%; 
            background: rgba(11,15,25,0.9); 
            z-index: 1000; 
            justify-content: center; 
            align-items: center; 
            backdrop-filter: blur(16px);
        }
        
        .modal.active { display: flex; animation: modalFadeIn 0.3s ease; }

        @keyframes modalFadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        .modal-content { 
            background: var(--bg-card);
            border: 1px solid var(--border-default);
            border-radius: 8px; 
            padding: 28px; 
            max-width: 1000px; 
            width: 95%; 
            max-height: 88vh; 
            overflow-y: auto; 
            box-shadow: var(--shadow-lg);
            animation: modalSlideIn 0.3s ease;
        }

        @keyframes modalSlideIn {
            from { transform: translateY(30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        .modal-header { 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            margin-bottom: 20px; 
            padding-bottom: 16px; 
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .modal-flag { font-size: 2rem; }
        
        .modal-title { 
            font-size: 1.375rem; 
            font-weight: 600; 
            color: var(--text-primary);
        }
        
        .close-btn { 
            margin-left: auto;
            width: 32px;
            height: 32px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            color: var(--text-secondary); 
            font-size: 1.25rem; 
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .close-btn:hover { 
            background: var(--bg-card-hover);
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr) 1.5fr;
            gap: 12px;
            margin-bottom: 24px;
        }

        .info-item {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 10px;
        }

        .info-label {
            color: #ffffff;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 4px;
            font-weight: 600;
        }

        .info-value {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .info-value.good {
            color: var(--accent-green);
        }

        .info-value.normal {
            color: var(--accent-gold);
        }

        .info-value.poor {
            color: var(--accent-red);
        }

        .storage-target-value {
            color: var(--accent-gold);
            font-weight: 600;
        }
        
        .info-value.accent { 
            color: var(--accent-gold);
        }
        
        .modal-desc {
            color: var(--text-secondary);
            font-size: 0.9375rem;
            line-height: 1.7;
            margin-bottom: 20px;
            padding: 16px;
            background: var(--bg-tertiary);
            border-radius: 6px;
            border-left: 3px solid var(--accent-gold);
        }
        
        .target-section {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 20px;
            margin-bottom: 20px;
        }
        
        .target-header {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .target-value {
            color: var(--accent-gold);
            font-size: 1.375rem;
            font-weight: 600;
        }
        
        .progress-bar { 
            background: var(--bg-primary); 
            border-radius: 4px; 
            height: 8px; 
            overflow: hidden;
            border: 1px solid var(--border-subtle);
        }
        
        .progress-fill { 
            height: 100%; 
            border-radius: 4px; 
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-teal));
            transition: width 0.8s ease;
        }
        
        .pie-row { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 16px; 
        }
        
        .pie-box {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 16px;
        }
        
        .pie-title {
            text-align: center;
            font-size: 0.8125rem;
            color: var(--text-secondary);
            margin-bottom: 14px;
            font-weight: 500;
        }
        
        .pie-container { width: 100%; height: 160px; }

        /* 区域装机详情弹窗 */
        .region-modal-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .region-modal-subtitle {
            font-size: 0.875rem;
            color: var(--text-tertiary);
            margin-bottom: 24px;
        }

        .region-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .region-stat-item {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 16px;
            text-align: center;
        }

        .region-stat-label {
            font-size: 0.75rem;
            color: var(--text-tertiary);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .region-stat-value {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--accent-gold);
        }

        .region-stat-unit {
            font-size: 0.75rem;
            color: var(--text-tertiary);
            margin-left: 2px;
        }

        .region-pie-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .region-pie-box {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 20px;
        }

        .region-pie-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
            text-align: center;
            margin-bottom: 16px;
        }

        .region-pie-container {
            width: 100%;
            height: 200px;
        }

        .capacity-table-section {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 20px;
        }

        .capacity-table-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 16px;
        }

        .capacity-table {
            width: 100%;
            border-collapse: collapse;
        }

        .capacity-table th,
        .capacity-table td {
            padding: 12px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border-subtle);
        }

        .capacity-table th {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .capacity-table td {
            font-size: 0.875rem;
            color: var(--text-primary);
        }

        .capacity-table tbody tr:hover {
            background: rgba(255,255,255,0.02);
        }

        .capacity-value {
            font-weight: 600;
        }

        .capacity-addition {
            color: var(--accent-teal);
            font-weight: 600;
        }

        /* 各国光储政策弹窗 */
        .policy-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        .policy-card {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 8px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .policy-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--accent-gold);
            transform: scaleY(0);
            transition: transform 0.3s ease;
        }

        .policy-card:hover::before {
            transform: scaleY(1);
        }

        .policy-card:hover {
            border-color: var(--accent-gold);
            background: rgba(201,162,39,0.05);
            transform: translateY(-2px);
        }

        .policy-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .policy-flag {
            font-size: 2rem;
        }

        .policy-name {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .policy-summary {
            font-size: 0.8125rem;
            color: var(--text-secondary);
            line-height: 1.6;
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .policy-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 12px;
        }

        .policy-tag {
            font-size: 0.6875rem;
            padding: 4px 8px;
            background: rgba(59,130,246,0.1);
            border: 1px solid rgba(59,130,246,0.2);
            border-radius: 4px;
            color: var(--accent-blue);
            font-weight: 500;
        }

        /* 政策详情弹窗 */
        .policy-detail-modal .modal-content {
            max-width: 900px;
        }

        .policy-detail-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 24px;
        }

        .policy-section {
            margin-bottom: 24px;
        }

        .policy-section-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--accent-gold);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border-subtle);
        }

        .policy-text {
            color: var(--text-secondary);
            font-size: 0.875rem;
            line-height: 1.8;
            margin-bottom: 12px;
        }

        .policy-text ul {
            padding-left: 20px;
            margin: 8px 0;
        }

        .policy-text li {
            margin-bottom: 6px;
        }

        .policy-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            color: var(--accent-teal);
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s ease;
            margin-top: 8px;
        }

        .policy-link:hover {
            border-color: var(--accent-teal);
            background: rgba(13,148,136,0.1);
        }

        .policy-highlights {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 12px;
            margin-top: 16px;
        }

        .highlight-item {
            background: rgba(201,162,39,0.08);
            border: 1px solid rgba(201,162,39,0.2);
            border-radius: 6px;
            padding: 12px;
        }

        .highlight-label {
            font-size: 0.75rem;
            color: var(--text-tertiary);
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .highlight-value {
            font-size: 1rem;
            font-weight: 600;
            color: var(--accent-gold);
        }

        .policy-footer {
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid var(--border-subtle);
        }
        
        .footer { 
            text-align: center; 
            padding: 24px; 
            color: var(--text-tertiary); 
            font-size: 0.8125rem; 
            margin-top: 24px;
            border-top: 1px solid var(--border-subtle);
        }
        
        /* 主题切换按钮 - 优化 */
        .theme-toggle {
            position: fixed;
            top: 24px;
            right: 32px;
            padding: 8px 16px;
            background: var(--bg-card);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            color: var(--text-secondary);
            font-size: 0.8125rem;
            cursor: pointer;
            transition: all 0.2s ease;
            z-index: 100;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .theme-toggle:hover {
            background: var(--bg-card-hover);
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }
        
        /* 浅色模式 - 商务风格 */
        body.light-mode {
            --bg-primary: #f8fafc;
            --bg-secondary: #ffffff;
            --bg-tertiary: #f1f5f9;
            --bg-card: #ffffff;
            --bg-card-hover: #f8fafc;
            --border-subtle: rgba(0,0,0,0.05);
            --border-default: rgba(0,0,0,0.08);
            --border-strong: rgba(0,0,0,0.12);
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --text-tertiary: #94a3b8;
            --accent-gold: #b8941f;
            --accent-gold-glow: rgba(184,148,31,0.25);
            --accent-blue: #2563eb;
            --accent-blue-glow: rgba(37,99,235,0.25);
            --accent-teal: #0d9488;
            --accent-teal-glow: rgba(13,148,136,0.25);
            --accent-navy: #334155;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
            --shadow: 0 4px 12px rgba(0,0,0,0.08);
            --shadow-lg: 0 10px 40px rgba(0,0,0,0.12);
        }

        body.light-mode::before {
            display: none;
        }

        /* 滚动条样式 */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-strong);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent-cyan);
        }

        /* 模态框样式 */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 10000;
            animation: modalFadeIn 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @keyframes modalFadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .modal-content {
            background: var(--bg-primary);
            border: 1px solid var(--border-default);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            max-width: 1400px;
            width: 95%;
            max-height: 90vh;
            overflow-y: auto;
            animation: modalSlideUp 0.3s ease;
        }

        @keyframes modalSlideUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 24px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-default);
            border-radius: 16px 16px 0 0;
        }

        .modal-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .modal-close {
            width: 36px;
            height: 36px;
            border: none;
            background: var(--bg-card);
            color: var(--text-secondary);
            font-size: 1.8rem;
            line-height: 1;
            cursor: pointer;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

        .modal-close:hover {
            background: var(--accent-gold);
            color: var(--bg-primary);
        }

        .export-btn {
            padding: 8px 16px;
            border: 1px solid var(--accent-gold);
            background: transparent;
            color: var(--accent-gold);
            font-size: 0.9rem;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .export-btn:hover {
            background: var(--accent-gold);
            color: var(--bg-primary);
        }

        .modal-body {
            padding: 24px;
        }

        /* 财务模型布局 */
        .financial-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        .params-panel,
        .results-panel {
            background: var(--bg-card);
            border: 1px solid var(--border-default);
            border-radius: 12px;
            overflow: hidden;
        }

        .params-panel-header {
            padding: 16px 20px;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-default);
            font-size: 1rem;
            font-weight: 600;
            color: var(--accent-gold);
        }

        .params-section {
            padding: 20px;
        }

        .param-group {
            margin-bottom: 20px;
        }

        .param-group:last-child {
            margin-bottom: 0;
        }

        .param-group-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border-subtle);
        }

        .param-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid var(--border-subtle);
        }

        .param-row:last-child {
            border-bottom: none;
        }

        .param-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .param-input {
            width: 120px;
            padding: 8px 12px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 0.85rem;
            transition: all 0.2s ease;
        }

        .param-input:focus {
            outline: none;
            border-color: var(--accent-gold);
            box-shadow: 0 0 0 3px var(--accent-gold-glow);
        }

        .param-input[readonly] {
            background: var(--bg-tertiary);
            color: var(--text-tertiary);
            cursor: not-allowed;
        }

        /* SOH 小板块 */
        .soh-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-default);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .soh-card:hover {
            border-color: var(--accent-blue);
            transform: translateY(-2px);
        }

        .soh-card-header {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--border-subtle);
        }

        .soh-card-icon {
            font-size: 1.4rem;
            margin-right: 10px;
        }

        .soh-card-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .soh-card-body {
            padding: 12px 16px;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .results-section {
            padding: 20px;
        }

        /* KPI 卡片 */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        .kpi-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-default);
            border-radius: 8px;
            padding: 16px;
            text-align: center;
            transition: all 0.2s ease;
        }

        .kpi-card:hover {
            border-color: var(--accent-gold);
            transform: translateY(-2px);
        }

        .kpi-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .kpi-value {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--accent-gold);
        }

        /* 图表容器 */
        .chart-container {
            background: var(--bg-secondary);
            border: 1px solid var(--border-default);
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
        }

        .chart-container:last-child {
            margin-bottom: 0;
        }

        .chart-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border-subtle);
        }

        #powerProfileChart,
        #cashFlowChart,
        #sohCurveChart {
            width: 100%;
            height: 300px;
        }

        /* SOH 表格 */
        .soh-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .soh-table th,
        .soh-table td {
            padding: 12px 16px;
            text-align: center;
            border: 1px solid var(--border-default);
        }

        .soh-table th {
            background: var(--bg-secondary);
            font-weight: 600;
            color: var(--accent-gold);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .soh-table td {
            color: var(--text-secondary);
        }

        .soh-table tr:hover {
            background: var(--bg-card-hover);
        }

        .soh-table tbody tr:nth-child(even) {
            background: var(--bg-tertiary);
        }

        .soh-table tbody tr:nth-child(even):hover {
            background: var(--bg-card-hover);
        }
        
        /* 国家政策自动刷新板块 */
        .policy-refresh-section {
            margin-top: 24px;
        }
        
        .policy-refresh-panel {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 8px;
            overflow: hidden;
        }
        
        .policy-refresh-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-subtle);
            background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
        }
        
        .policy-refresh-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .policy-refresh-title::before {
            content: '';
            width: 3px;
            height: 16px;
            background: var(--accent-teal);
            border-radius: 1px;
        }
        
        .policy-refresh-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .policy-refresh-status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8125rem;
            color: var(--text-tertiary);
        }
        
        .policy-refresh-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent-teal);
            animation: pulse 2s infinite;
        }
        
        .policy-refresh-dot.updating {
            background: var(--accent-gold);
        }
        
        .policy-refresh-dot.error {
            background: var(--accent-red);
            animation: none;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
        }
        
        .policy-refresh-btn {
            padding: 6px 14px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 4px;
            color: var(--accent-teal);
            font-size: 0.8125rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .policy-refresh-btn:hover {
            background: var(--accent-teal);
            color: var(--bg-primary);
            border-color: var(--accent-teal);
        }
        
        .policy-refresh-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .policy-refresh-body {
            padding: 20px;
        }
        
        /* 政策筛选器 */
        .policy-filters {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }
        
        .policy-filter-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .policy-filter-label {
            font-size: 0.75rem;
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .policy-filter-select {
            padding: 6px 12px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 4px;
            color: var(--text-primary);
            font-size: 0.8125rem;
            cursor: pointer;
            min-width: 120px;
        }
        
        .policy-filter-select:focus {
            outline: none;
            border-color: var(--accent-teal);
        }
        
        .policy-search-input {
            padding: 6px 12px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 4px;
            color: var(--text-primary);
            font-size: 0.8125rem;
            min-width: 200px;
        }
        
        .policy-search-input:focus {
            outline: none;
            border-color: var(--accent-teal);
        }
        
        .policy-search-input::placeholder {
            color: var(--text-tertiary);
        }
        
        /* 政策列表 */
        .policy-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 12px;
            max-height: 400px;
            overflow-y: auto;
        }
        
        .policy-list::-webkit-scrollbar {
            width: 6px;
        }
        
        .policy-list::-webkit-scrollbar-track {
            background: var(--bg-tertiary);
            border-radius: 3px;
        }
        
        .policy-list::-webkit-scrollbar-thumb {
            background: var(--border-strong);
            border-radius: 3px;
        }
        
        .policy-item {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 6px;
            padding: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .policy-item:hover {
            border-color: var(--accent-teal);
            background: var(--bg-card-hover);
        }
        
        .policy-item-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        
        .policy-item-country {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        
        .policy-item-flag {
            font-size: 1.1rem;
        }
        
        .policy-item-badge {
            padding: 2px 8px;
            border-radius: 3px;
            font-size: 0.6875rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        
        .policy-item-badge.national {
            background: rgba(201, 162, 39, 0.15);
            color: var(--accent-gold);
        }
        
        .policy-item-badge.market {
            background: rgba(59, 130, 246, 0.15);
            color: var(--accent-blue);
        }
        
        .policy-item-badge.subsidy {
            background: rgba(34, 197, 94, 0.15);
            color: var(--accent-green);
        }
        
        .policy-item-badge.standard {
            background: rgba(139, 92, 246, 0.15);
            color: #8b5cf6;
        }
        
        .policy-item-badge.international {
            background: rgba(236, 72, 153, 0.15);
            color: #ec4899;
        }
        
        .policy-item-title {
            font-size: 0.8125rem;
            color: var(--text-primary);
            line-height: 1.5;
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .policy-item-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.75rem;
            color: var(--text-tertiary);
        }
        
        .policy-item-date {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        .policy-item-importance {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        .policy-importance-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }
        
        .policy-importance-dot.high {
            background: var(--accent-red);
        }
        
        .policy-importance-dot.medium {
            background: var(--accent-gold);
        }
        
        .policy-importance-dot.low {
            background: var(--accent-teal);
        }
        
        /* 政策详情弹窗 */
        .policy-refresh-detail-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(11, 15, 25, 0.9);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(16px);
        }
        
        .policy-refresh-detail-modal.active {
            display: flex;
            animation: modalFadeIn 0.3s ease;
        }
        
        .policy-refresh-detail-content {
            background: var(--bg-card);
            border: 1px solid var(--border-default);
            border-radius: 8px;
            padding: 28px;
            max-width: 800px;
            width: 95%;
            max-height: 88vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
        }
        
        .policy-refresh-detail-header {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border-subtle);
        }
        
        .policy-refresh-detail-flag {
            font-size: 2.5rem;
        }
        
        .policy-refresh-detail-info {
            flex: 1;
        }
        
        .policy-refresh-detail-country {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 4px;
        }
        
        .policy-refresh-detail-title {
            font-size: 1rem;
            color: var(--text-secondary);
        }
        
        .policy-refresh-detail-meta {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            font-size: 0.8125rem;
            color: var(--text-tertiary);
        }
        
        .policy-refresh-detail-content-inner {
            color: var(--text-secondary);
            font-size: 0.9375rem;
            line-height: 1.8;
        }
        
        .policy-refresh-detail-content-inner p {
            margin-bottom: 12px;
        }
        
        .policy-refresh-detail-close {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 32px;
            height: 32px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            color: var(--text-secondary);
            font-size: 1.25rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .policy-refresh-detail-close:hover {
            background: var(--bg-card-hover);
            border-color: var(--accent-gold);
            color: var(--accent-gold);
        }
        
        /* Toast 通知 */
        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            padding: 12px 20px;
            background: var(--bg-card);
            border: 1px solid var(--border-default);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 0.875rem;
            z-index: 3000;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: var(--shadow-lg);
            animation: slideIn 0.3s ease;
        }
        
        .toast.success {
            border-color: var(--accent-teal);
        }
        
        .toast.error {
            border-color: var(--accent-red);
        }
        
        @keyframes slideIn {
            from { transform: translateX(100px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
