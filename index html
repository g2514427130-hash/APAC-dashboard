        // 全局变量
        let currentPolicies = [];
        let lastRefreshTime = null;
        let refreshInterval = null;

        // 初始化政策列表
        function initPolicies() {
            // 从localStorage读取缓存数据
            const cachedData = localStorage.getItem('policyRefreshData');
            const cachedTime = localStorage.getItem('policyRefreshTime');
            
            if (cachedData && cachedTime) {
                const timeDiff = Date.now() - parseInt(cachedTime);
                const oneHour = 60 * 60 * 1000;
                const oneDay = 24 * 60 * 60 * 1000;
                
                // 如果缓存超过1天，显示需要刷新
                if (timeDiff > oneDay) {
                    updateRefreshStatus('需要刷新', 'updating');
                } else if (timeDiff > oneHour) {
                    updateRefreshStatus('可刷新', '');
                } else {
                    lastRefreshTime = new Date(parseInt(cachedTime));
                    updateRefreshStatus('最后更新: ' + formatDateTime(lastRefreshTime), '');
                }
                
                // 使用缓存数据
                currentPolicies = JSON.parse(cachedData);
                renderPolicies();
            } else {
                // 首次加载，执行刷新
                setTimeout(() => refreshPolicies(), 500);
            }
            
            // 设置定时刷新检查（每小时）
            startRefreshInterval();
        }

        // 刷新政策数据
        function refreshPolicies() {
            const btn = document.getElementById('policyRefreshBtn');
            const dot = document.getElementById('policyRefreshDot');
            
            btn.disabled = true;
            btn.innerHTML = '<span>⏳</span><span>刷新中...</span>';
            dot.classList.add('updating');
            dot.classList.remove('error');
            updateRefreshStatus('正在刷新...', 'updating');
            
            // 模拟从API获取数据（实际项目中应替换为真实API调用）
            setTimeout(() => {
                // 收集所有政策
                const allPolicies = [];
                for (const [countryKey, country] of Object.entries(policyData)) {
                    for (const policy of country.policies) {
                        allPolicies.push({
                            ...policy,
                            countryKey: countryKey,
                            countryName: country.name,
                            countryFlag: country.flag
                        });
                    }
                }
                
                // 按日期排序（最新的在前）
                allPolicies.sort((a, b) => new Date(b.date) - new Date(a.date));
                
                // 保存到全局变量和localStorage
                currentPolicies = allPolicies;
                lastRefreshTime = new Date();
                localStorage.setItem('policyRefreshData', JSON.stringify(allPolicies));
                localStorage.setItem('policyRefreshTime', Date.now().toString());
                
                // 更新UI
                renderPolicies();
                updateRefreshStatus('最后更新: ' + formatDateTime(lastRefreshTime), '');
                
                btn.disabled = false;
                btn.innerHTML = '<span>🔄</span><span>刷新政策</span>';
                dot.classList.remove('updating');
                
                showToast('政策数据已更新，共 ' + allPolicies.length + ' 条最新政策', 'success');
            }, 1500);
        }

        // 筛选政策
        function filterPolicies() {
            const countryFilter = document.getElementById('policyCountryFilter').value;
            const typeFilter = document.getElementById('policyTypeFilter').value;
            const importanceFilter = document.getElementById('policyImportanceFilter').value;
            const searchText = document.getElementById('policySearchInput').value.toLowerCase();
            
            // 获取所有政策
            const allPolicies = [];
            for (const [countryKey, country] of Object.entries(policyData)) {
                for (const policy of country.policies) {
                    allPolicies.push({
                        ...policy,
                        countryKey: countryKey,
                        countryName: country.name,
                        countryFlag: country.flag
                    });
                }
            }
            
            // 筛选
            let filtered = allPolicies.filter(policy => {
                if (countryFilter && policy.countryKey !== countryFilter) return false;
                if (typeFilter && policy.type !== typeFilter) return false;
                if (importanceFilter && policy.importance !== importanceFilter) return false;
                if (searchText) {
                    return policy.title.toLowerCase().includes(searchText) || 
                           policy.summary.toLowerCase().includes(searchText);
                }
                return true;
            });
            
            // 排序
            filtered.sort((a, b) => new Date(b.date) - new Date(a.date));
            
            // 渲染
            renderPolicies(filtered);
        }

        // 渲染政策列表
        function renderPolicies(policiesToRender) {
            const container = document.getElementById('policyList');
            const policies = policiesToRender || currentPolicies;
            
            if (!policies || policies.length === 0) {
                container.innerHTML = `
                    <div class="policy-empty">
                        <div class="policy-empty-icon">📭</div>
                        <div class="policy-empty-text">暂无符合条件的政策</div>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = policies.map(policy => `
                <div class="policy-item" onclick="showPolicyDetail('${policy.id}')">
                    <div class="policy-item-header">
                        <div class="policy-item-country">
                            <span class="policy-item-flag">${policy.countryFlag}</span>
                            <span>${policy.countryName}</span>
                        </div>
                        <span class="policy-item-badge ${policy.type}">${policy.typeName}</span>
                    </div>
                    <div class="policy-item-title">${policy.title}</div>
                    <div class="policy-item-meta">
                        <div class="policy-item-date">
                            <span>📅</span>
                            <span>${formatDate(policy.date)}</span>
                            ${policy.source ? `<span style="margin-left: 8px;">📢</span><span>${policy.source}</span>` : ''}
                        </div>
                        <div class="policy-item-importance">
                            <span class="policy-importance-dot ${policy.importance}"></span>
                            <span>${getImportanceText(policy.importance)}</span>
                        </div>
                    </div>
                    ${policy.url ? `<a href="${policy.url}" target="_blank" class="policy-source-link" style="margin-top: 8px; font-size: 0.75rem; color: var(--accent-teal); text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" onclick="event.stopPropagation();">🔗 官方原文</a>` : ''}
                </div>
            `).join('');
        }

        // 显示政策详情
